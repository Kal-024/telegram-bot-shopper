# ─── Configuración Multi-Tenant ───────────────────────────────────────────
# Token del Bot Maestro (admin) - Créalo en @BotFather
ADMIN_BOT_TOKEN=tu_token_del_bot_admin_aqui

# ID de Telegram del super-administrador (tú)
SUPER_ADMIN_ID=123456789

# ─── Compatibilidad con modo standalone (opcional) ───────────────────────
# Estos valores se usan SOLO si ejecutas main.py directamente (sin launcher.py)
# o durante la primera migración automática al nuevo sistema.
BOT_TOKEN=tu_token_aqui
CHANNEL_ID=@tuCodigoDeCanal
STORE_NAME=MI TIENDA
AUTHORIZED_USERS=123456789

# ─── Persistencia de Datos ────────────────────────────────────────────────
# Si se provee, los datos se guardarán en MongoDB en lugar de archivos JSON locales.
# MONGO_URL=mongodb://username:password@host:port/
# MONGO_DB=telegram_shopper
